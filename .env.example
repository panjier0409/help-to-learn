# App
SECRET_KEY=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# Public-facing site URL (no trailing slash). Used to build share links in Telegram/Anki messages.
# Example: https://learn.example.com
SITE_BASE_URL=http://localhost:5173

# Database & Storage
DATABASE_URL=sqlite:///./data.db
STORAGE_BASE_PATH=./storage

# wangwangit/tts Cloudflare Worker URL
TTS_WORKER_URL=
# SiliconFlow token for STT (optional, uses default if empty)
TTS_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# AnkiConnect (local, requires Anki + AnkiConnect plugin)
ANKI_CONNECT_URL=http://localhost:8765

# Worker poll interval in seconds
JOB_POLL_INTERVAL=5

# ── Proxy Settings ────────────────────────────────────────────────────────────
# Used for both HTTP requests (STT/TTS API calls) and yt-dlp video downloads.
# Supports http://, https://, socks5:// schemes.
# Example: http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:10808
HTTPS_PROXY=http://127.0.0.1:10808
# Optional: override proxy specifically for yt-dlp (falls back to HTTP_PROXY)
YTDLP_PROXY=
# Path to Netscape-format cookies.txt for yt-dlp authenticated downloads.
# If left empty, auto-detects ./cookies.txt in the working directory.
YTDLP_COOKIES=
